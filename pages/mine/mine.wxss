/* pages/mine/mine.wxss - 我的页面样式 */

.container {
  padding: 24rpx;
}

/* 用户卡片 */
.user-card {
  margin-bottom: 24rpx;
}

.user-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 20rpx 0;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.user-id {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 统计卡片 */
.stats-card {
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 菜单列表 */
.menu-list {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* 版本信息 */
.version-info {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 40rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 16rpx 0;
}
