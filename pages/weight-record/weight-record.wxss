/* pages/weight-record/weight-record.wxss - 体重记录页样式 */

.container {
  padding: 24rpx;
}

.form-card {
  margin-bottom: 32rpx;
}

.pet-info {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 24rpx;
}

.pet-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.record-type {
  font-size: 26rpx;
  color: var(--text-hint);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.input-field {
  background-color: var(--bg-color);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.weight-input {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
}

.picker-field {
  background-color: var(--bg-color);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.food-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.food-tag {
  padding: 12rpx 24rpx;
  background-color: var(--bg-color);
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.food-tag.active {
  background-color: var(--primary-color);
  color: #FFFFFF;
}

.submit-section {
  padding: 24rpx 0 40rpx;
}

.submit-btn {
  background-color: var(--primary-color);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: bold;
  padding: 28rpx;
  border-radius: 44rpx;
  border: none;
  margin-bottom: 24rpx;
}

.delete-btn {
  background-color: #FF4444;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: bold;
  padding: 28rpx;
  border-radius: 44rpx;
  border: none;
}
