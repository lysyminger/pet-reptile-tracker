/* pages/add-pet/add-pet.wxss - 添加宠物页样式 */

.container {
  padding: 24rpx;
}

.form-card {
  margin-bottom: 32rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 24rpx;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: var(--bg-color);
  margin-bottom: 24rpx;
}

.avatar-actions {
  display: flex;
  flex-direction: row;
}

.avatar-btn {
  font-size: 26rpx;
  color: var(--primary-color);
  background-color: transparent;
  border: 2rpx solid var(--primary-color);
  border-radius: 32rpx;
  padding: 12rpx 32rpx;
}

/* 表单区域 */
.form-section {
  padding: 0 8rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.input-field {
  background-color: var(--bg-color);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.picker-field {
  background-color: var(--bg-color);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  position: relative;
}

.picker-field.placeholder {
  color: var(--text-hint);
}

.picker-field .picker-text {
  flex: 1;
}

.picker-field .picker-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-left: 16rpx;
}

.picker-hover {
  background-color: #E0E8E5;
}

/* 频率选择器 */
.frequency-selector {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.freq-btn {
  padding: 16rpx 28rpx;
  background-color: var(--bg-color);
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.freq-btn.active {
  background-color: var(--primary-color);
  color: #FFFFFF;
}

/* 提交区域 */
.submit-section {
  padding: 24rpx 0 40rpx;
}

.submit-btn {
  background-color: var(--primary-color);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: bold;
  padding: 28rpx;
  border-radius: 44rpx;
  border: none;
  margin-bottom: 24rpx;
}

.delete-btn {
  background-color: transparent;
  color: var(--danger-color);
  font-size: 28rpx;
  padding: 20rpx;
  border-radius: 44rpx;
  border: 2rpx solid var(--danger-color);
}
