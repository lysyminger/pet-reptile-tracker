/* pages/pet-gallery/pet-gallery.wxss */
.container { padding: 24rpx; }

.grid {
  display: flex;
  flex-wrap: wrap;
}

/* 3 列网格 */
.cell {
  width: calc((100% - 2 * 16rpx) / 3);
  height: 0;
  padding-bottom: calc((100% - 2 * 16rpx) / 3);
  position: relative;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: var(--bg-color);
}
/* 每行第 3 个去掉右边距 */
.cell:nth-child(3n) { margin-right: 0; }

.photo-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}

.add-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed var(--border-color);
  background-color: #FAFAFA;
}
.add-cell .add-plus { position: absolute; top: 50%; left: 0; right: 0; transform: translateY(-70%); text-align: center; font-size: 60rpx; color: var(--text-hint); }
.add-cell .add-text { position: absolute; bottom: 18%; left: 0; right: 0; text-align: center; font-size: 22rpx; color: var(--text-hint); }

.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 26rpx; color: var(--text-hint); text-align: center; }

.tip {
  margin-top: 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-hint);
}
