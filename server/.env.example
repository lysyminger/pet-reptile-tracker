# 部署时把这个文件复制为 .env 并填入实际值
# 然后通过宝塔的「文件」面板把 .env 权限设为 600（只有所有者可读写）

# 微信小程序密钥（mp.weixin.qq.com 后台获取）
WX_APPID=wx72f836c54512f38f
WX_APPSECRET=replace_with_your_new_appsecret

# JWT 签名密钥，随便用 openssl rand -hex 32 生成一串
JWT_SECRET=replace_with_random_64_char_hex_string

# MySQL 连接
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pet_reptile
DB_USER=pet_reptile
DB_PASS=replace_with_your_mysql_password

# 上传文件的对外 URL 前缀（应该指向 /uploads/ 目录）
UPLOAD_URL_PREFIX=https://api.lysyminger.online/uploads

# 微信「消息推送」回调校验 Token（内容安全异步检测结果推送用）
# 自己用 openssl rand -hex 16 生成，要和 mp 后台「消息推送」里填的 Token 一致
WX_MSG_TOKEN=replace_with_random_hex_string
